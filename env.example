# ─────────────────────────────────────────────
# Publicador Zap — Variables de entorno
# Copia este archivo como .env y llena los valores
# ─────────────────────────────────────────────

# Flask
FLASK_ENV=development
SECRET_KEY=cambia-esto-por-64-caracteres-aleatorios

# Base de datos
# Dev: omitir (usa SQLite automáticamente)
# Prod: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Encriptación de tokens ML en DB
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Mercado Libre
ML_CLIENT_ID=3509386763056859
ML_CLIENT_SECRET=tu-client-secret-aqui

# Tokens ML legacy (prototipo — se migran a DB en Paso 4)
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# Admin por defecto (usado por flask seed-db)
ADMIN_EMAIL=admin@publicadorzap.com
ADMIN_PASSWORD=cambia-esto-en-produccion
