# ─────────────────────────────────────────────
# Miraarlo Replicator — Variables de entorno
# Copia este archivo como .env y llena los valores
# ─────────────────────────────────────────────

# Flask
SECRET_KEY=cambia-esto-por-una-clave-segura

# Mercado Libre — App de Miraarlo
ML_CLIENT_ID=tu-client-id-aqui
ML_CLIENT_SECRET=tu-client-secret-aqui
ML_REDIRECT_URI=http://localhost:5000/auth/callback

# Tokens ML (se actualizan automáticamente al reconectar)
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
